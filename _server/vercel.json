{
  "version": 2,
  "builds": [
    {
      "src": "dist/src/main.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/src/main.js"
    }
  ],
  "crons": [
    {
      "path": "/internal/notify-upcoming-sessions",
      "schedule": "*/10 * * * *"
    }
  ]
}
