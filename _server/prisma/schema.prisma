generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model bookings {
  id                                     String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id                             String                @db.Uuid
  tutor_id                               String                @db.Uuid
  tutor_offer_id                         String?               @db.Uuid
  start_at                               DateTime              @db.Timestamptz(6)
  end_at                                 DateTime              @db.Timestamptz(6)
  duration_minutes                       Int
  price                                  Decimal               @db.Decimal(10, 2)
  status                                 booking_status?       @default(pending)
  created_at                             DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at                             DateTime?             @default(now()) @db.Timestamptz(6)
  /// coins deducted from student at booking creation
  coins_cost                             Int?                  @default(0)
  tutor_availability_id                  String?               @db.Uuid
  reschedule_notes                       String?
  reschedule_proposed_end                DateTime?             @db.Timestamptz(6)
  /// reschedule fields — set when tutor proposes a new time
  reschedule_proposed_start              DateTime?             @db.Timestamptz(6)
  reschedule_requested_by                String?               @db.Uuid
  /// set once session reminder notification is sent — prevents duplicates
  session_notified_at                    DateTime?             @db.Timestamptz(6)
  /// student's reason for booking — shown to tutor before they confirm
  description                            String?
  /// auto-decline pending bookings after this time (1 hour from creation)
  expires_at                             DateTime?             @db.Timestamptz(6)
  price_proposal_expires_at              DateTime?             @db.Timestamptz(6)
  price_proposal_message                 String?
  /// price negotiation — tutor proposes higher cost, student accepts/rejects
  price_proposed_coins                   Int?
  profiles_bookings_student_idToprofiles profiles              @relation("bookings_student_idToprofiles", fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tutor_availabilities                   tutor_availabilities? @relation(fields: [tutor_availability_id], references: [id], onUpdate: NoAction)
  profiles_bookings_tutor_idToprofiles   profiles              @relation("bookings_tutor_idToprofiles", fields: [tutor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tutor_offers                           tutor_offers?         @relation(fields: [tutor_offer_id], references: [id], onUpdate: NoAction)
  messages                               messages[]
  reviews                                reviews[]
  transactions                           transactions[]

  @@index([start_at], map: "idx_bookings_start_at")
  @@index([student_id], map: "idx_bookings_student")
  @@index([tutor_id], map: "idx_bookings_tutor")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model messages {
  id                                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  from_id                             String    @db.Uuid
  to_id                               String    @db.Uuid
  booking_id                          String?   @db.Uuid
  content                             String
  metadata                            Json?     @default("{}")
  created_at                          DateTime? @default(now()) @db.Timestamptz(6)
  is_read                             Boolean?  @default(false)
  bookings                            bookings? @relation(fields: [booking_id], references: [id], onUpdate: NoAction)
  profiles_messages_from_idToprofiles profiles  @relation("messages_from_idToprofiles", fields: [from_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles_messages_to_idToprofiles   profiles  @relation("messages_to_idToprofiles", fields: [to_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([from_id, to_id, created_at(sort: Desc)], map: "idx_messages_conversation")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model notifications {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id String    @db.Uuid
  type       String
  payload    Json?
  seen       Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  profiles   profiles  @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([profile_id], map: "idx_notifications_profile")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model profiles {
  id                                     String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name                              String?
  username                               String?
  avatar_url                             String?
  bio                                    String?
  role                                   String                 @default("STUDENT")
  book_price                             Decimal                @db.Decimal(10, 2)
  subjects                               String[]
  created_at                             DateTime?              @default(now()) @db.Timestamptz(6)
  updated_at                             DateTime?              @default(now()) @db.Timestamptz(6)
  overall_rating                         Decimal?               @default(0) @db.Decimal
  rating_count                           Int?                   @default(0)
  tutor_rating                           Decimal?               @db.Decimal
  student_rating                         Decimal?               @db.Decimal
  email                                  String?                @unique
  password                               String?
  is_email_verified                      Boolean                @default(false)
  coins_balance                          Int                    @default(0)
  /// PENDING | APPROVED | REJECTED — only set for TUTOR role
  verification_status                    String?
  /// Numeric 10-digit ID for ADMIN accounts — used instead of email for admin login
  admin_id                               String?                @unique
  /// coin rate for bookings — coins per hour
  book_price_coins                       Int                    @default(10)
  ban_reason                             String?
  banned_at                              DateTime?              @db.Timestamptz(6)
  /// admin_id string of the admin who issued the ban
  banned_by                              String?
  deactivated_at                         DateTime?              @db.Timestamptz(6)
  deactivated_by                         String?
  /// false = temporarily deactivated by admin (reversible)
  is_active                              Boolean                @default(true)
  /// true = permanently banned by admin
  is_banned                              Boolean                @default(false)
  /// forced price reduction % while penalty active (0-100)
  penalty_price_pct                      Int                    @default(0)
  /// subtract from overall_rating while penalty active
  penalty_rating_knock                   Decimal                @default(0) @db.Decimal
  /// penalty active until this timestamp; null = no active penalty
  penalty_until                          DateTime?              @db.Timestamptz(6)
  last_seen_at                           DateTime?              @db.Timestamptz(6)
  /// ONLINE | OFFLINE | BUSY — updated by client heartbeat or explicit call
  user_status                            String                 @default("OFFLINE")
  bookings_bookings_student_idToprofiles bookings[]             @relation("bookings_student_idToprofiles")
  bookings_bookings_tutor_idToprofiles   bookings[]             @relation("bookings_tutor_idToprofiles")
  coin_transactions                      coin_transactions[]
  messages_messages_from_idToprofiles    messages[]             @relation("messages_from_idToprofiles")
  messages_messages_to_idToprofiles      messages[]             @relation("messages_to_idToprofiles")
  notifications                          notifications[]
  payment_orders                         payment_orders[]
  reviews_reviews_reviewee_idToprofiles  reviews[]              @relation("reviews_reviewee_idToprofiles")
  reviews_reviews_reviewer_idToprofiles  reviews[]              @relation("reviews_reviewer_idToprofiles")
  transactions                           transactions[]
  tutor_availabilities                   tutor_availabilities[]
  tutor_offers                           tutor_offers[]
  tutor_verifications                    tutor_verifications?
  withdrawal_requests                    withdrawal_requests[]

  @@index([role], map: "idx_profiles_is_tutor")
  @@index([verification_status], map: "idx_profiles_verification_status")
}

/// Stores encrypted PII for tutor identity verification. Admin-only read access.
model tutor_verifications {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tutor_id        String    @unique @db.Uuid
  /// AES-256-GCM encrypted phone number
  phone_enc       String?
  /// AES-256-GCM encrypted address
  address_enc     String?
  /// AES-256-GCM encrypted URL to uploaded government ID document
  id_document_enc String?
  /// AES-256-GCM encrypted JSON array of certificate URLs
  cert_urls_enc   String?
  submitted_at    DateTime? @default(now()) @db.Timestamptz(6)
  reviewed_at     DateTime? @db.Timestamptz(6)
  reviewed_by     String?   @db.Uuid
  admin_notes     String?
  profiles        profiles  @relation(fields: [tutor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tutor_id], map: "idx_tutor_verifications_tutor")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model reviews {
  id                                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id                             String?   @db.Uuid
  reviewer_id                            String    @db.Uuid
  reviewee_id                            String    @db.Uuid
  rating                                 Int
  comment                                String?
  created_at                             DateTime? @default(now()) @db.Timestamptz(6)
  bookings                               bookings? @relation(fields: [booking_id], references: [id], onUpdate: NoAction)
  profiles_reviews_reviewee_idToprofiles profiles  @relation("reviews_reviewee_idToprofiles", fields: [reviewee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles_reviews_reviewer_idToprofiles profiles  @relation("reviews_reviewer_idToprofiles", fields: [reviewer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([reviewee_id], map: "idx_reviews_reviewee")
  @@index([reviewee_id], map: "idx_reviews_reviewee_id")
}

model subjects {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String    @unique
  name        String
  description String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model transactions {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id       String           @db.Uuid
  booking_id       String?          @db.Uuid
  amount           Decimal          @db.Decimal(12, 2)
  currency         String?          @default("USD") @db.VarChar(8)
  kind             transaction_kind
  provider_payload Json?
  status           String           @default("pending")
  created_at       DateTime?        @default(now()) @db.Timestamptz(6)
  bookings         bookings?        @relation(fields: [booking_id], references: [id], onUpdate: NoAction)
  profiles         profiles         @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([profile_id], map: "idx_transactions_profile")
}

model tutor_availabilities {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tutor_id       String     @db.Uuid
  available_from DateTime   @db.Timestamptz(6)
  available_to   DateTime   @db.Timestamptz(6)
  timezone       String?
  created_at     DateTime?  @default(now()) @db.Timestamptz(6)
  bookings       bookings[]
  profiles       profiles   @relation(fields: [tutor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tutor_id], map: "idx_tutor_availabilities_tutor")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tutor_offers {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tutor_id         String     @db.Uuid
  title            String
  summary          String?
  about            String?
  price_per_hour   Decimal    @db.Decimal(10, 2)
  duration_minutes Int        @default(60)
  subject_ids      String[]   @default([]) @db.Uuid
  is_active        Boolean?   @default(true)
  created_at       DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?  @default(now()) @db.Timestamptz(6)
  /// session price in coins (overrides profile book_price_coins when set)
  coins_per_hour   Int        @default(10)
  thumbnail_url    String?
  bookings         bookings[]
  profiles         profiles   @relation(fields: [tutor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([is_active], map: "idx_tutor_offers_active")
  @@index([tutor_id], map: "idx_tutor_offers_tutor")
}

/// Coin ledger — one row per credit/debit event
model coin_transactions {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id String    @db.Uuid
  /// positive = credit, negative = debit
  amount     Int
  /// WELCOME_BONUS | PURCHASE | BOOKING_PAYMENT | REFUND | ADJUSTMENT
  kind       String
  /// ref to bookings.id or payment_orders.id if applicable
  ref_id     String?   @db.Uuid
  note       String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  profiles   profiles  @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([profile_id], map: "idx_coin_transactions_profile")
}

/// Tracks fiat payment sessions for coin purchases
model payment_orders {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id          String    @db.Uuid
  coins_amount        Int
  fiat_amount         Decimal   @db.Decimal(10, 2)
  currency            String    @default("IDR") @db.VarChar(8)
  /// PENDING | COMPLETED | FAILED | REFUNDED
  status              String    @default("PENDING")
  /// midtrans | etc.
  provider            String    @default("midtrans")
  provider_session_id String?
  provider_payload    Json?
  refund_reason       String?
  refunded_at         DateTime? @db.Timestamptz(6)
  refunded_by         String?   @db.Uuid
  created_at          DateTime? @default(now()) @db.Timestamptz(6)
  updated_at          DateTime? @default(now()) @db.Timestamptz(6)
  /// Midtrans transaction_id for QRIS
  qris_ref            String?
  profiles            profiles  @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([profile_id], map: "idx_payment_orders_profile")
  @@index([status], map: "idx_payment_orders_status")
}

/// Tutor cashout requests — admin processes payout manually
model withdrawal_requests {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tutor_id       String    @db.Uuid
  coins_amount   Int
  idr_amount     Decimal   @db.Decimal(12, 2)
  /// PENDING | APPROVED | REJECTED | PAID
  status         String    @default("PENDING")
  account_name   String
  account_number String
  /// QRIS | BANK_TRANSFER | GOPAY | OVO | DANA
  payment_method String    @default("QRIS")
  bank_name      String?
  admin_notes    String?
  processed_by   String?   @db.Uuid
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  updated_at     DateTime? @default(now()) @db.Timestamptz(6)
  profiles       profiles  @relation(fields: [tutor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tutor_id], map: "idx_withdrawal_requests_tutor")
  @@index([status], map: "idx_withdrawal_requests_status")
}

enum booking_status {
  pending
  confirmed
  cancelled
  completed
  failed
  declined
  rescheduling
  expired
}

enum transaction_kind {
  booking_payment
  payout
  refund
  adjustment
}
