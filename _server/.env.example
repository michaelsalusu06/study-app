# Environment variables for the backend
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres"
PORT=3000

JWT_SECRET="replace-with-strong-random-secret"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Comma-separated allowed CORS origins. Example: https://your-app.vercel.app,https://admin.your-app.com
CORS_ORIGIN=""

# Strong random string for Vercel Cron → /internal/* auth
INTERNAL_SECRET="replace-with-strong-random-secret"

ADMIN_PUBLIC_KEY_B64=""
ADMIN_PRIVATE_KEY_B64=""
ADMIN_BOOTSTRAP_SECRET="replace-with-strong-random-secret"
